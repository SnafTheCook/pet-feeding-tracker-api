@page "/edit-pet/{Id:int}"
@using DidWeFeedTheCatToday.Shared.DTOs.Pets
@using DidWeFeedTheCatToday.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject PetService PetClient
@inject NavigationManager NavManager

<h3>Edit Pet</h3>

@if (editModel == null)
{
    <p><em>Loading pet data...</em></p>
}
else
{
    <div class="card p-4 shadow-sm" style="max-width: 500px;">
        <EditForm Model="@editModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText @bind-Value="editModel.Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Age</label>
                <InputNumber @bind-Value="editModel.Age" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Additional Info</label>
                <InputTextArea @bind-Value="editModel.AdditionalInformation" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private CommandPetDTO? editModel;

    private bool showToast = false;
    private string toastMessage = "Unhadled exception.";
    private string toastClass = "bg-success";

    protected override async Task OnInitializedAsync()
    {
        var result = await PetClient.GetPetByIdAsync(Id);

        if (result != null)
        {
            editModel = new CommandPetDTO
            {
                Name = result.Name,
                Age = result.Age,
                AdditionalInformation = result.AdditionalInformation,
                RowVersion = result.RowVersion
            };
        }
        else
        {
            NavManager.NavigateTo("/pets");
        }
    }

    private async Task HandleSubmit()
    {
        var success = await PetClient.UpdatePetAsync(Id, editModel!);

        if (success)
        {
            NavManager.NavigateTo("/pets");
        }
        else
        {
            toastMessage = "This pet was modified by another user. Please refresh and try again.";
            await ShowToast(toastMessage, isError: true);
        }
    }

    private void Cancel() => NavManager.NavigateTo("/pets");

    private async Task ShowToast(string message = "Something went wrong. Try again later.", bool isError = false)
    {
        toastMessage = message;
        toastClass = isError ? "bg-danger" : "bg-success";
        showToast = true;
        StateHasChanged();

        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }
}

@if (showToast)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-white @toastClass border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @toastMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => showToast = false"></button>
            </div>
        </div>
    </div>
}